# Learning Assistant Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Required: OpenAI API Key
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ===========================================
# Database Configuration
# ===========================================
# For SQLite (development/single user):
DATABASE_URL=sqlite:///./data/learning_assistant.db

# For PostgreSQL (production/multi-user):
# DATABASE_URL=postgresql://user:password@localhost:5432/learning_assistant
POSTGRES_USER=learning_assistant
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=learning_assistant

# ===========================================
# Security
# ===========================================
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# Optional: Redis Cache
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# LLM Configuration
# ===========================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===========================================
# User Preferences (Legacy/Default)
# ===========================================
USER_INTERESTS_STR=machine learning,deep learning,natural language processing,computer vision

# ===========================================
# API Configuration
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===========================================
# Optional: Semantic Scholar API
# ===========================================
# SEMANTIC_SCHOLAR_API_KEY=your-key-here
